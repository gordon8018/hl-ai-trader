          "type": "frser-sqlite-datasource",
          "uid": "efez6mngjjwu8c"
        },
        "targets": [
          {
            "rawQueryText": "SELECT equity_usd - (SELECT equity_usd FROM state_snapshots WHERE ts >= date('now') ORDER BY ts ASC LIMIT 1) AS 'Daily PnL' FROM state_snapshots ORDER BY ts DESC LIMIT 1",
            "queryType": "table",
            "datasource": {
              "type": "frser-sqlite-datasource",
              "uid": "efez6mngjjwu8c"
            }
          }
        ],
        "fieldConfig": {
          "defaults": {
