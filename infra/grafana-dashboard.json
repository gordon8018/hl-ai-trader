    "panels": [
      {
        "id": 1,
        "title": "\ud83d\udcb0 \u6743\u76ca\u66f2\u7ebf (Equity)",
        "type": "timeseries",
        "gridPos": {
          "h": 8,
          "w": 24,
          "x": 0,
          "y": 0
        },
        "datasource": {
          "type": "frser-sqlite-datasource",
          "uid": "efez6mngjjwu8c"
        },
        "targets": [
          {
            "rawQueryText": "SELECT ts AS time, equity_usd AS 'Equity ($)', cash_usd AS 'Cash ($)' FROM state_snapshots ORDER BY ts",
            "queryType": "table",
            "timeColumns": [
              "time"
            ],
            "datasource": {
              "type": "frser-sqlite-datasource",
              "uid": "efez6mngjjwu8c"
            }
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "currencyUSD",
            "custom": {
              "lineWidth": 2,
              "fillOpacity": 10,
              "pointSize": 1,
              "showPoints": "never"
            }
          },
          "overrides": [
            {
              "matcher": {
                "id": "byName",
                "options": "Cash ($)"
              },
              "properties": [
                {
                  "id": "custom.lineStyle",
                  "value": {
                    "fill": "dash",
                    "dash": [
                      10,
                      10
                    ]
                  }
                },
                {
                  "id": "custom.fillOpacity",
                  "value": 0
                }
              ]
            }
          ]
        },
        "options": {
          "tooltip": {
            "mode": "multi"
          },
          "legend": {
            "displayMode": "table",
            "calcs": [
              "lastNotNull",
              "min",
              "max"
            ]
          }
        }
      },
      {
        "id": 2,
        "title": "\ud83d\udcc8 \u672a\u5b9e\u73b0\u76c8\u4e8f (Unrealized PnL)",
        "type": "timeseries",
        "gridPos": {
          "h": 8,
          "w": 24,
          "x": 0,
          "y": 8
        },
        "datasource": {
          "type": "frser-sqlite-datasource",
          "uid": "efez6mngjjwu8c"
        },
        "targets": [
          {
            "rawQueryText": "SELECT ts AS time, (equity_usd - cash_usd) AS 'Unrealized PnL ($)' FROM state_snapshots ORDER BY ts",
            "queryType": "table",
            "timeColumns": [
              "time"
            ],
            "datasource": {
              "type": "frser-sqlite-datasource",
              "uid": "efez6mngjjwu8c"
            }
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "currencyUSD",
            "custom": {
              "lineWidth": 2,
              "fillOpacity": 20,
              "gradientMode": "scheme",
              "pointSize": 1,
              "showPoints": "never",
              "thresholdsStyle": {
                "mode": "line"
              }
            },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "color": "red",
                  "value": null
                },
                {
                  "color": "green",
                  "value": 0
                }
              ]
            },
            "color": {
              "mode": "continuous-GrYlRd"
            }
          }
        },
        "options": {
          "tooltip": {
            "mode": "multi"
          },
          "legend": {
            "displayMode": "table",
            "calcs": [
              "lastNotNull",
              "min",
              "max"
            ]
          }
        }
      },
