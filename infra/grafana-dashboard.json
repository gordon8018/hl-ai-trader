      {
        "id": 7,
        "title": "\ud83d\udcb5 \u603b\u655e\u53e3 (Gross Exposure %)",
        "type": "timeseries",
        "gridPos": {
          "h": 6,
          "w": 12,
          "x": 0,
          "y": 28
        },
        "datasource": {
          "type": "frser-sqlite-datasource",
          "uid": "efez6mngjjwu8c"
        },
        "targets": [
          {
            "rawQueryText": "SELECT ts AS time, CASE WHEN equity_usd > 0 THEN ((equity_usd - cash_usd) / equity_usd * 100) ELSE 0 END AS 'Gross Exposure (%)' FROM state_snapshots ORDER BY ts",
            "queryType": "table",
            "timeColumns": [
              "time"
            ],
            "datasource": {
              "type": "frser-sqlite-datasource",
              "uid": "efez6mngjjwu8c"
            }
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "custom": {
              "lineWidth": 2,
              "fillOpacity": 15,
              "showPoints": "never"
            },
            "max": 50,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "color": "green",
                  "value": null
                },
                {
                  "color": "yellow",
                  "value": 30
                },
                {
                  "color": "red",
                  "value": 40
                }
              ]
            }
          }
        }
      },
      {
        "id": 8,
        "title": "\ud83d\udccb \u6210\u4ea4\u8bb0\u5f55 (Execution Reports)",
        "type": "table",
        "gridPos": {
          "h": 8,
          "w": 24,
          "x": 0,
          "y": 34
        },
        "datasource": {
          "type": "frser-sqlite-datasource",
          "uid": "efez6mngjjwu8c"
        },
        "targets": [
          {
            "rawQueryText": "SELECT ts AS 'Time', symbol AS 'Symbol', status AS 'Status', client_order_id AS 'Order ID', filled_qty AS 'Filled Qty', avg_px AS 'Avg Price', fee AS 'Fee', latency_ms AS 'Latency (ms)' FROM exec_reports ORDER BY ts DESC LIMIT 50",
            "queryType": "table",
            "timeColumns": [
              "Time"
            ],
            "datasource": {
              "type": "frser-sqlite-datasource",
              "uid": "efez6mngjjwu8c"
            }
          }
        ],
        "fieldConfig": {
          "overrides": [
            {
              "matcher": {
                "id": "byName",
                "options": "Status"
              },
              "properties": [
                {
                  "id": "mappings",
                  "value": [
                    {
                      "type": "value",
                      "options": {
                        "ACK": {
                          "color": "blue",
                          "text": "ACK"
                        },
                        "FILLED": {
                          "color": "green",
                          "text": "FILLED"
                        },
                        "REJECTED": {
                          "color": "red",
                          "text": "REJECTED"
                        },
                        "CANCELED": {
                          "color": "orange",
                          "text": "CANCELED"
                        }
                      }
                    }
                  ]
                }
              ]
            }
          ]
        }
      },
