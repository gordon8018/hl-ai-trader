# infra/.env.example
# Copy to infra/.env and fill in real values (never commit infra/.env)
#
# NOTE: ai_decision trading parameters (MAX_GROSS, CAP_ALT, AI_TURNOVER_CAP, etc.)
# are now managed in config/trading_params.json. Edit that file to tune strategy.

# ── Hyperliquid credentials (required) ────────────────
HL_ACCOUNT_ADDRESS=
HL_PRIVATE_KEY=
HL_HTTP_URL=https://api.hyperliquid.xyz

# ── Trading mode ──────────────────────────────────────
DRY_RUN=true

# ── Redis ─────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
REDIS_SOCKET_TIMEOUT_SEC=60
REDIS_SOCKET_CONNECT_TIMEOUT_SEC=10
REDIS_HEALTH_CHECK_INTERVAL_SEC=30
REDIS_XREADGROUP_RETRIES=3
REDIS_XREADGROUP_RETRY_DELAY_SEC=1.0
# Optional service-level override (SERVICE_NAME prefix)
# AI_DECISION_REDIS_SOCKET_TIMEOUT_SEC=90

# ── Trading universe ───────────────────────────────────
# Used by execution / market_data / portfolio_state / risk_engine.
# ai_decision reads UNIVERSE from config/trading_params.json instead.
UNIVERSE=BTC,ETH,SOL,ADA,DOGE

# ── Market data ───────────────────────────────────────
MD_PRICE_HISTORY_MINUTES=310
MD_EXEC_REPORT_SCAN_LIMIT=200
MD_EXEC_REPORT_SCAN_EVERY_SEC=120

# ── Ops service ───────────────────────────────────────
OPS_API_KEY=
